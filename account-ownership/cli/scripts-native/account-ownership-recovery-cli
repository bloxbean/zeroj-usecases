#!/usr/bin/env bash
# Native-binary launcher. Auto-sizes -Xmx for the heavy commands (`prove`, `setup`) — the native
# image's default heap address space is too small for the ~70-90 GB they need. Light commands
# (verify, info, import, export-r1cs) run with the default heap (fast startup, no reservation).
# Override the heap for any command with AOR_JAVA_OPTS, e.g. AOR_JAVA_OPTS="-Xmx90g".
# (no `set -u`: macOS bash 3.2 rejects empty-array expansion under it)
set -eo pipefail

DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN="$DIR/account-ownership-recovery-cli.bin"
if [[ ! -x "$BIN" ]]; then echo "native binary not found: $BIN" >&2; exit 1; fi

# the subcommand is the first non-option argument
SUB=""
for a in "$@"; do case "$a" in -*) ;; *) SUB="$a"; break ;; esac; done

JVM_ARGS=()
if [[ -n "${AOR_JAVA_OPTS:-}" ]]; then
  # user override applies to any command
  read -r -a JVM_ARGS <<< "$AOR_JAVA_OPTS"
elif [[ "$SUB" == "prove" || "$SUB" == "setup" ]]; then
  # auto-size to ~80% of RAM for the heavy commands
  if [[ "$(uname)" == "Darwin" ]]; then
    MEM_BYTES=$(sysctl -n hw.memsize)
  else
    MEM_BYTES=$(( $(awk '/MemTotal/{print $2}' /proc/meminfo) * 1024 ))
  fi
  XMX_MB=$(( MEM_BYTES / 1024 / 1024 * 80 / 100 ))
  [[ $XMX_MB -lt 2048 ]] && XMX_MB=2048
  JVM_ARGS=("-Xmx${XMX_MB}m")
fi

# -Xmx must precede the subcommand for the native runtime to consume it
exec "$BIN" "${JVM_ARGS[@]}" "$@"
